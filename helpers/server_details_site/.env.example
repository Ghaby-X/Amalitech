# Application Environment Configuration Example
# Copy this file to .env or pass these environment variables during container launch

# Port on which the HTTP server will listen (Default: 3000)
PORT=3000

# Directory path where SQLite database and storage files will be kept (Default: ./data)
DATA_DIR=./data

# SQLite Database Filename (Default: database.sqlite)
DB_NAME=database.sqlite

# Node Environment Mode (development / production)
NODE_ENV=production

# How often the dashboard polls /api/server-info for live metrics, in milliseconds (Default: 3000)
REFRESH_INTERVAL_MS=3000
